{
  "info": {
    "name": "GMS - Sistema Gestión Gimnasio",
    "description": "Colección completa de APIs para Sistema de Gestión de Gimnasio.\nBackend: Spring Boot 3.5.13 | Base de datos: MySQL 8.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "🔐 AUTENTICACIÓN",
      "description": "Servicios de autenticación (registro, login, refresh token)",
      "item": [
        {
          "name": "Registro",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "    let data = pm.response.json().data;",
                  "    if (data.accessToken) {",
                  "        pm.environment.set('access_token', data.accessToken);",
                  "    }",
                  "    if (data.refreshToken) {",
                  "        pm.environment.set('refresh_token', data.refreshToken);",
                  "    }",
                  "    pm.test('Registro exitoso', function () {",
                  "        pm.expect(pm.response.json().success).to.equal(true);",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"usuario_nuevo\", \"email\": \"nuevo@ejemplo.com\", \"password\": \"Password@123\", \"nombre\": \"Juan\", \"apellido\": \"Pérez\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/registro",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "registro"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    let data = pm.response.json().data;",
                  "    if (data.accessToken) {",
                  "        pm.environment.set('access_token', data.accessToken);",
                  "    }",
                  "    if (data.refreshToken) {",
                  "        pm.environment.set('refresh_token', data.refreshToken);",
                  "    }",
                  "    pm.test('Login exitoso', function () {",
                  "        pm.expect(pm.response.json().success).to.equal(true);",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"admin\", \"password\": \"admin123\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        },
        {
          "name": "Refrescar Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"refreshToken\": \"{{refresh_token}}\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "refresh"]
            }
          }
        }
      ]
    },
